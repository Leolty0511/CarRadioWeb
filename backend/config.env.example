# 阿里云OSS配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id-here
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret-here
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 服务器配置
PORT=3000
NODE_ENV=production

# CORS配置 - 支持生产环境和本地开发
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004,http://localhost:5173,http://localhost:4173,http://automotivehu.com,https://automotivehu.com,http://www.automotivehu.com,https://www.automotivehu.com

# JWT密钥（生产环境必须配置，至少32字符，不要使用示例值！）
# 生成方法：openssl rand -hex 32
JWT_SECRET=change-this-to-your-secure-jwt-key-in-production

# 首个超级管理员初始化密钥（生产环境必须配置强随机值）
# 生成方法：openssl rand -hex 32
ADMIN_BOOTSTRAP_TOKEN=change-this-bootstrap-token

# 数据加密密钥（用于加密存储敏感信息如 API 密钥）
# 生成方法：openssl rand -hex 32
# 生产环境必须配置！
ENCRYPTION_KEY=

# OpenAI API配置
OPENAI_API_KEY=your-openai-api-key-here

# 钉钉机器人配置（表单提交通知）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token-here
DINGTALK_SECRET=your-secret-here

# ==================== 新增：优化工具配置 ====================

# Redis 缓存配置（可选，不配置则使用内存缓存）
# REDIS_URL=redis://localhost:6379

# Sentry 错误监控配置（可选）
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# 应用版本号（用于 Sentry 版本追踪）
APP_VERSION=1.0.0

# ==================== OAuth 认证配置（已弃用） ====================
# 以下 OAuth 配置已不再使用，保留仅供参考

# Google OAuth（从 Google Cloud Console 获取）
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth（从 GitHub Developer Settings 获取）
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth 回调基础 URL（生产环境填写实际域名）
# OAUTH_CALLBACK_BASE=http://localhost:3000

# ==================== SMTP 邮箱配置（用于验证码发送） ====================
# 支持：网易163/126、QQ邮箱、Gmail、Outlook、阿里企业邮箱等
# 注意：网易和QQ邮箱需要使用授权码而非登录密码

# SMTP 服务器地址
SMTP_HOST=127.0.0.1
# SMTP 端口（SSL通常为465，TLS通常为587）
SMTP_PORT=1025
# 是否使用 SSL（465端口通常为true）
SMTP_SECURE=false
# SMTP 用户名（通常是邮箱地址）
SMTP_USER=
# SMTP 密码或授权码
SMTP_PASS=
# 发件人地址（默认使用 SMTP_USER）
SMTP_FROM=noreply@localhost

# 前端 URL（OAuth 登录成功后重定向目标）
FRONTEND_URL=http://localhost:3001

# ==================== HTTP 代理（可选） ====================
# 国内开发环境需要代理才能访问 Google/GitHub OAuth 服务
# 取消注释并填写你的本地代理地址，常见端口：7890/7897/1080/10809
# 生产环境（海外服务器）不需要配置此项
# HTTPS_PROXY=http://127.0.0.1:7890
