# Docker Compose 环境变量
# 复制此文件为 .env 并填入实际值

# MongoDB 配置
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_password_here

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# First super admin bootstrap token.
# Use a strong random value; enter it once on /admin during first setup.
ADMIN_BOOTSTRAP_TOKEN=change-this-bootstrap-token

# Local SMTP capture for verification codes.
# Docker Compose includes Mailpit; open http://127.0.0.1:8025 to view emails.
# For real email delivery, replace these with any SMTP provider values.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
